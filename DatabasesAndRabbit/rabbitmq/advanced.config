[
  {rabbit, [
    {consumer_timeout, 1200000},  % 20 минут
    {heartbeat, 60},
    {channel_max, 2047},
    {connection_max, 1000},
    {vm_memory_high_watermark, 0.7},
    {vm_memory_high_watermark_paging_ratio, 0.75}
  ]},
  {rabbitmq_management, [
    {rates_mode, basic}
    % Убираем sample_retention_policies - в версии 4.2.x это вызывает ошибку
    % Если нужны метрики, используйте другой подход
  ]}
].
