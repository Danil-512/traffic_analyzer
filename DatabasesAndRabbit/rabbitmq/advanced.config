[
  {rabbit, [
    % Таймауты и лимиты
    {consumer_timeout, 1200000},          % 20 минут (согласовано с docker-compose)
    {heartbeat, 60},                      % Увеличен до 60 сек для стабильности
    {frame_max, 262144},                  % Максимальный размер фрейма 256KB
    {channel_max, 2047},                  % Максимум каналов на соединение
    {connection_max, 1000},               % Защита от перегрузки соединениями
    
    % Оптимизация хранилища сообщений
    {msg_store_credit_disc_bound, {4000, 800}},
    {queue_index_embed_msgs_below, 4096}, % Мелкие сообщения хранить в индексе
    
    % Планировщик очередей
    {queue_master_locator, <<"min-masters">>},
    
    % Настройки памяти (важно для анализатора)
    {vm_memory_high_watermark, 0.7},      % Использовать до 70% RAM
    {vm_memory_high_watermark_paging_ratio, 0.75}
  ]},
  
  % Настройки management плагина
  {rabbitmq_management, [
    {sample_retention_policies, [
      {global, [{60, 5}]}                % Хранить детальные метрики 5 минут
    ]},
    {rates_mode, basic}                   % Базовый сбор метрик для экономии CPU
  ]},
  
  % Настройки очередей по умолчанию
  {rabbitmq_management_agent, [
    {force_fine_statistics, false}       % Отключаем детальную статистику для производительности
  ]}
].