% advanced.config
%
[
  {rabbit, [
    % Таймауты и лимиты
    {consumer_timeout, 300000},           % 5 минут на обработку сообщения
    {heartbeat, 30},                      % Проверка соединения каждые 30 сек
    {frame_max, 262144},                  % Максимальный размер фрейма 256KB
    {channel_max, 2047},                  % Максимум каналов на соединение
    {connection_max, 1000},               % Защита от перегрузки соединениями
    %
    % Сбор метрик (оптимизация)
    %{collect_statistics_interval, 10000}, % Сбор статистики каждые 10 сек
    %
    % Оптимизация хранилища сообщений
    {msg_store_credit_disc_bound, {4000, 800}},
    {queue_index_embed_msgs_below, 4096}, % Мелкие сообщения хранить в индексе
    %
    % Планировщик очередей
    {queue_master_locator, <<"min-masters">>}
  ]},
  %
  % Настройки management плагина
  {rabbitmq_management, [
    {sample_retention_policies, [
      {global, [{60, 5}]}                % Хранить детальные метрики 5 минут
    ]}
  ]}
].